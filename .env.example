# ── Application ───────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DATABASE_URL=postgresql+psycopg2://rag_user:rag_password@localhost:5432/rag_db

# ── OpenSearch ────────────────────────────────────────────────────────────────
# Use localhost when running services directly; container name inside Docker
OPENSEARCH_HOST=http://localhost:9200
OPENSEARCH__HOST=http://localhost:9200
OPENSEARCH__INDEX_NAME=arxiv-papers
OPENSEARCH__MAX_TEXT_SIZE=1000000

# ── Embeddings (required) ─────────────────────────────────────────────────────
# Get your key at https://jina.ai/
JINA_API_KEY=your_jina_api_key_here

# ── LLM Backend — pick one ────────────────────────────────────────────────────

# Option A: Ollama (local, no key needed)
OLLAMA_HOST=http://localhost:11434

# Option B: OpenAI (set OPENAI__ENABLED=true to activate)
OPENAI__ENABLED=false
OPENAI__API_KEY=your_openai_api_key_here
OPENAI__MODEL=gpt-4o-mini
OPENAI__TEMPERATURE=0.0

# ── arXiv Ingestion ───────────────────────────────────────────────────────────
ARXIV__MAX_RESULTS=15
ARXIV__BASE_URL=https://export.arxiv.org/api/query
ARXIV__PDF_CACHE_DIR=./data/arxiv_pdfs
ARXIV__RATE_LIMIT_DELAY=5.0
ARXIV__TIMEOUT_SECONDS=30
ARXIV__SEARCH_CATEGORY=cs.AI
ARXIV__DOWNLOAD_MAX_RETRIES=3
ARXIV__DOWNLOAD_RETRY_DELAY_BASE=5.0
ARXIV__MAX_CONCURRENT_DOWNLOADS=5

# ── PDF Parser ────────────────────────────────────────────────────────────────
PDF_PARSER__MAX_PAGES=30
PDF_PARSER__MAX_FILE_SIZE_MB=20
PDF_PARSER__DO_OCR=false
PDF_PARSER__DO_TABLE_STRUCTURE=true

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS__HOST=localhost
REDIS__PORT=6379

# ── Langfuse Observability (optional) ────────────────────────────────────────
# Self-hosted at http://localhost:3000 — create a project to get these keys
LANGFUSE__ENABLED=false
LANGFUSE__HOST=http://localhost:3000
LANGFUSE__PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE__SECRET_KEY=your_langfuse_secret_key_here

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram to get a token
TELEGRAM__ENABLED=false
TELEGRAM__BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM__API_BASE_URL=http://localhost:8000
